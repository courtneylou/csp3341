<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.nook.controller.WishlistPageController"
      spacing="0"
      styleClass="main-container">

    <!-- Navigation Bar -->
    <HBox styleClass="navbar" alignment="CENTER_LEFT" spacing="15">
        <Text text="Nook" styleClass="nav-logo"/>
        <Button text="← Back" onAction="#handleBack" styleClass="link-button"/>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
        <VBox spacing="20" styleClass="detail-container">

            <Label text="My Wishlist" styleClass="page-title"/>
            <Label fx:id="errorLabel" styleClass="error-label"/>

            <ScrollPane fitToWidth="true" styleClass="books-scroll">
                <FlowPane fx:id="booksGrid"
                          styleClass="books-grid"
                          hgap="20"
                          vgap="20"/>
            </ScrollPane>

        </VBox>
    </ScrollPane>

</VBox>