<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.nook.controller.LoginController"
      alignment="CENTER"
      spacing="15"
      styleClass="auth-container">

    <Text text="Nook" styleClass="app-title"/>
    <Text text="Welcome back" styleClass="auth-subtitle"/>

    <VBox spacing="10" styleClass="auth-form">

        <Label text="Username"/>
        <TextField fx:id="usernameField" promptText="Enter your username"/>

        <Label text="Password"/>
        <PasswordField fx:id="passwordField" promptText="Enter your password"/>

        <Label fx:id="errorLabel" styleClass="error-label"/>

        <Button text="Log In" onAction="#handleLogin" styleClass="primary-button" maxWidth="Infinity" defaultButton="true"/>

        <HBox alignment="CENTER" spacing="5">
            <Label text="Don't have an account?"/>
            <Button text="Sign Up" onAction="#handleGoToRegister" styleClass="link-button"/>
        </HBox>

    </VBox>

</VBox>