<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.nook.controller.RegisterController"
      alignment="CENTER"
      spacing="15"
      styleClass="auth-container">

    <Text text="Nook" styleClass="app-title"/>
    <Text text="Create your account" styleClass="auth-subtitle"/>

    <VBox spacing="10" styleClass="auth-form">

        <Label text="Username"/>
        <TextField fx:id="usernameField" promptText="Choose a username"/>

        <Label text="Email"/>
        <TextField fx:id="emailField" promptText="Enter your email"/>

        <Label text="Password"/>
        <PasswordField fx:id="passwordField" promptText="Choose a password"/>

        <Label text="Confirm Password"/>
        <PasswordField fx:id="confirmPasswordField" promptText="Confirm your password"/>

        <Label fx:id="errorLabel" styleClass="error-label"/>

        <Button text="Create Account" onAction="#handleRegister" styleClass="primary-button" maxWidth="Infinity" defaultButton="true"/>

        <HBox alignment="CENTER" spacing="5">
            <Label text="Already have an account?"/>
            <Button text="Log In" onAction="#handleGoToLogin" styleClass="link-button"/>
        </HBox>

    </VBox>

</VBox>